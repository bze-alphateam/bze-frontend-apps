# The interchain-kit / cosmos / chakra ecosystem declares loose peer deps.
# Don't fail installs on peer mismatches, and auto-provide peers where sensible.
strict-peer-dependencies=false
auto-install-peers=true

# Chakra UI v3's inferred types reference @zag-js internals. Under pnpm's nested
# layout TypeScript can't emit a portable .d.ts reference to them (error TS2742),
# so hoist @zag-js to the root node_modules the way npm's flat layout used to.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*@zag-js*
